{
  "name": "solophp/router",
  "type": "library",
  "description": "A lightweight and flexible PHP router with middleware support, route groups, and named routes",
    "keywords": [
    "router",
    "routing",
    "php-router",
    "middleware",
    "route-groups",
    "named-routes",
    "php8",
    "psr-4"
    ],
  "license": "MIT",
  "authors": [
    {
      "name": "Vitaliy Olos",
            "email": "vedastudio@gmail.com",
            "role": "Developer"
    }
  ],
  "autoload": {
    "psr-4": {
      "Solo\\Router\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Solo\\Router\\Tests\\": "tests/"
    }
  },
  "require": {
        "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "scripts": {
    "test": "phpunit",
    "cs": "phpcs --standard=PSR12 src/ tests/",
    "cs-fix": "phpcbf --standard=PSR12 src/ tests/"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
